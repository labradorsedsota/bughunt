    .map((item) => {
      const url = `/classes/${baseClass.src}/${item.key}`;
      return { title: item.name, url };
    });
  output[output.findIndex(el => el.title === baseClass.title)].subroutes  // Line 100: ERROR HERE
    = subClassesForClass;  // Line 100
}
```

